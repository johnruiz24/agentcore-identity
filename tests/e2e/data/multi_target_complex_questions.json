[
  {
    "id": "cross_release_readout",
    "question": "List Jira projects and open high-priority issues, then create a release-readout calendar event for tomorrow morning.",
    "steps": [
      {
        "logical_tool": "atlassian.list_accessible_resources",
        "arguments": {}
      },
      {
        "logical_tool": "atlassian.search_projects",
        "arguments": {
          "cloudId": "{{cloudId}}",
          "maxResults": 10
        }
      },
      {
        "logical_tool": "atlassian.search_issues",
        "arguments": {
          "cloudId": "{{cloudId}}",
          "jql": "priority in (Highest, High) AND statusCategory != Done ORDER BY updated DESC",
          "maxResults": 5
        }
      },
      {
        "logical_tool": "google.create_calendar_event",
        "arguments": {
          "calendarId": "primary",
          "summary": "Release Readout + Jira Risks",
          "description": "Generated by multi-target E2E scenario",
          "start": {
            "dateTime": "{{tomorrow_start_iso}}",
            "timeZone": "Europe/Lisbon"
          },
          "end": {
            "dateTime": "{{tomorrow_end_iso}}",
            "timeZone": "Europe/Lisbon"
          }
        }
      }
    ]
  },
  {
    "id": "cross_incident_followup",
    "question": "Find open incident-like Jira issues and schedule a 30-minute incident follow-up with engineering.",
    "steps": [
      {
        "logical_tool": "atlassian.list_accessible_resources",
        "arguments": {}
      },
      {
        "logical_tool": "atlassian.search_issues",
        "arguments": {
          "cloudId": "{{cloudId}}",
          "jql": "text ~ \"incident\" AND statusCategory != Done ORDER BY created DESC",
          "maxResults": 5
        }
      },
      {
        "logical_tool": "google.create_calendar_event",
        "arguments": {
          "calendarId": "primary",
          "summary": "Incident Follow-up",
          "description": "Follow-up based on Jira incident search",
          "start": {
            "dateTime": "{{tomorrow_start_iso}}",
            "timeZone": "Europe/Lisbon"
          },
          "end": {
            "dateTime": "{{tomorrow_end_iso}}",
            "timeZone": "Europe/Lisbon"
          }
        }
      }
    ]
  },
  {
    "id": "atlassian_project_discovery",
    "question": "Show projects I can access in Jira and fetch recent unresolved issues.",
    "steps": [
      {
        "logical_tool": "atlassian.list_accessible_resources",
        "arguments": {}
      },
      {
        "logical_tool": "atlassian.search_projects",
        "arguments": {
          "cloudId": "{{cloudId}}",
          "maxResults": 20
        }
      },
      {
        "logical_tool": "atlassian.search_issues",
        "arguments": {
          "cloudId": "{{cloudId}}",
          "jql": "statusCategory != Done ORDER BY updated DESC",
          "maxResults": 10
        }
      }
    ]
  },
  {
    "id": "calendar_only_schedule",
    "question": "Create a calendar event for tomorrow to review top Jira blockers.",
    "steps": [
      {
        "logical_tool": "google.create_calendar_event",
        "arguments": {
          "calendarId": "primary",
          "summary": "Review Jira Blockers",
          "description": "Calendar-only scenario in multi-target suite",
          "start": {
            "dateTime": "{{tomorrow_start_iso}}",
            "timeZone": "Europe/Lisbon"
          },
          "end": {
            "dateTime": "{{tomorrow_end_iso}}",
            "timeZone": "Europe/Lisbon"
          }
        }
      }
    ]
  }
]
